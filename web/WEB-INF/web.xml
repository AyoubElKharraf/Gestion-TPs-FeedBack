<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>MiniProjet-BE4</display-name>

    <!-- URL du système externe Gestion_AbsencesAlerts / AbsTrack (pour signalement des absences et API absences-par-enseignant).
         - Même machine : http://localhost:8080/GestionAA (AbsTrack sur 8080).
         - Deux machines (EtudAcadPro sur PC1:8081, AbsTrack sur PC2:8080) : remplacer par l'IP du PC où tourne AbsTrack, ex. http://192.168.1.10:8080/GestionAA -->
    <context-param>
        <param-name>absence.system.url</param-name>
        <param-value>http://localhost:8081/AbsTrack</param-value>
    </context-param>

    <!-- Filtre d'authentification -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>util.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/vues/*</url-pattern>
    </filter-mapping>

    <!-- Page d'accueil -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>